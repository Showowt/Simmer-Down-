# ═══════════════════════════════════════════════════════════════
# Simmer Down — Environment Variables
# Copy to .env.local and fill in real values. Never commit .env.local.
# ═══════════════════════════════════════════════════════════════

# ─── SUPABASE ───
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-only. Used for payment_attempts writes & RLS bypass.
SUPABASE_SERVICE_ROLE_KEY=

# ─── APP ───
# Base URL used to construct MerchantResponseUrl for Powertranz 3DS callback.
# Must be publicly reachable in prod (https://). In dev, use ngrok/cloudflared if testing 3DS.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ─── FAC / POWERTRANZ (BAC Credomatic) ───
# Credentials arrive via Mimecast encrypted email from postmaster@fac.bm.
# Sandbox API root: https://staging.ptranz.com/api/
# Production API root: https://gateway.ptranz.com/api/
FAC_API_ROOT=https://staging.ptranz.com/api/
FAC_POWERTRANZ_ID=
FAC_POWERTRANZ_PASSWORD=
# ISO 4217 numeric currency code. 840 = USD (El Salvador uses USD).
FAC_CURRENCY_CODE=840

# HMAC secret used to sign iframe-to-parent postMessage payloads.
# Generate with: openssl rand -hex 32
PAYMENT_CALLBACK_SECRET=

# ─── ANTHROPIC (Sophia / Anima) ───
ANTHROPIC_API_KEY=

# ─── TWILIO WHATSAPP ───
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── THIRD-PARTY DELIVERY WEBHOOK SECRETS ───
# Each provider signs inbound webhooks differently; store shared secrets here.
UBER_EATS_WEBHOOK_SECRET=
DOORDASH_WEBHOOK_SECRET=
PEDIDOS_YA_WEBHOOK_SECRET=
HUGO_WEBHOOK_SECRET=

# ─── VERCEL (deploy) ───
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
